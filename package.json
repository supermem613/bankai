{
  "name": "bankai",
  "version": "0.5.0",
  "description": "Agentic-first orchestration engine for reliable dev-loop, test, and tool workflows",
  "type": "module",
  "bin": {
    "bankai": "./dist/cli.js"
  },
  "files": [
    "dist/",
    ".claude/skills/",
    "docs/",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "eslint src/ test/ && tsc --noEmit -p test/tsconfig.json",
    "build": "npm run clean && tsc",
    "test": "node test/run.mjs test/**/*.test.ts",
    "test:unit": "node test/run.mjs test/unit/**/*.test.ts",
    "test:integration": "node test/run.mjs test/integration/**/*.test.ts",
    "coverage": "c8 --reporter=text --all --include \"src/**/*.ts\" --exclude \"src/**/interface.ts\" --exclude \"src/**/types.ts\" --exclude \"src/plan/envelope.ts\" --exclude \"src/cli.ts\" node test/run.mjs test/**/*.test.ts",
    "coverage:check": "c8 --check-coverage --lines 74 --branches 64 --functions 83 --all --include \"src/**/*.ts\" --exclude \"src/**/interface.ts\" --exclude \"src/**/types.ts\" --exclude \"src/plan/envelope.ts\" --exclude \"src/cli.ts\" node test/run.mjs test/**/*.test.ts",
    "lint": "eslint src/ test/ && tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentic",
    "orchestration",
    "dev-loop",
    "test-automation",
    "cli"
  ],
  "author": "Marcus Markiewicz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supermem613/bankai.git"
  },
  "bugs": {
    "url": "https://github.com/supermem613/bankai/issues"
  },
  "homepage": "https://github.com/supermem613/bankai#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.15.0",
    "c8": "^11.0.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "minimatch": "^10.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
