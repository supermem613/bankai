{
  "schemaVersion": "1",
  "name": "node-server-self",
  "description": "Self-test for persistent setup: starts a node http server via managed-process, waits on the port to come up, then leaves it registered. Use bankai stop node-server-self to tear it down.",
  "steps": [
    {
      "id": "boot",
      "kind": "setup",
      "env": "managed-process",
      "registerAs": "node-server-self",
      "config": {
        "command": "node",
        "args": ["scripts/canary-server.cjs"],
        "cwd": ".",
        "logFile": ".bankai/logs/canary-server.log",
        "env": {
          "PORT": "47391"
        }
      },
      "setupTimeoutMs": 10000
    },
    {
      "id": "ready",
      "kind": "wait",
      "fromStepId": "boot",
      "for": [
        {
          "kind": "port",
          "id": "p1",
          "host": "127.0.0.1",
          "port": 47391
        }
      ],
      "timeoutMs": 10000,
      "pollIntervalMs": 200
    }
  ]
}
